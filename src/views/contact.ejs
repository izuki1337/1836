<%- include('./partials/head') %>
<body>
  <%- include('./partials/header') %>

  <main style="padding-top: 80px; min-height: 80vh; display: flex; align-items: center;">
    <section class="section contact-section" style="width: 100%;">
      <div class="vcard-wrapper cinematic-reveal">
        <div class="vcard-header">
          <div class="vcard-status">
            <span class="status-dot"></span>
            <span><%= profile.availability %></span>
          </div>
          <h1 class="vcard-name"><%= profile.name %></h1>
          <p class="vcard-role"><%= profile.role %></p>
        </div>
        <div class="vcard-body">
          <p class="vcard-intro">Đây là một góc nhỏ cá nhân. Không mục đích công việc, không ồn ào. Chỉ là nơi tôi lưu giữ những mảnh ghép của riêng mình và tận hưởng sự tĩnh lặng.</p>
          <div class="vcard-links">
            <% socialLinks.forEach((link) => { %>
              <a href="<%= link.href %>" class="vcard-link-item" target="_blank" rel="noopener noreferrer">
                <span class="vcard-link-label"><%= link.label %></span>
                <span class="vcard-link-note"><%= link.note %></span>
              </a>
            <% }) %>
          </div>
        </div>
        <div class="vcard-footer">
          <a href="currently none" class="vcard-email">currently none &nearr;</a>
        </div>
      </div>
    </section>
  </main>

  <%- include('./partials/footer') %>